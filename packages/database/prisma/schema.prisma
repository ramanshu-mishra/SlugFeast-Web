
generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "commonjs"
}

datasource db {
  provider = "postgresql"
}


model user{
  publicKey String @id @unique
  username String?
  name String?
  email String?
  countryCode String?
  contact String?
  coins coin[]
  coinsHeld holding[]
  apiKeys apiKeys[]
  messages message[]
  
}

model holding{
  coinAddress String 
  amount BigInt 
  userAddress String 
  user user @relation(fields: [userAddress], references: [publicKey])
  coin coin @relation(fields: [coinAddress], references: [address])
  @@id([coinAddress, userAddress])
}

model socials{
  id String @id @unique @default(cuid())
  instagram String?
  x String?
  telegram String?
  youtube String?
  website String?
  coin coin @relation(fields: [coinId], references: [id])
  coinId String @unique 
}


model coin{
  id String @id @default(cuid())
  address String? @unique 
  tokenName String 
  symbol String
  imageUrl String
  description String
  TokenAmount String @default("800000000000000")
  VETHAmount String @default("4000000000000000000")
  ATHPrice String @default("5000000000000")

  user user @relation(fields: [userId], references: [publicKey])
  holdings holding[]
  messages message[]
  userId String
  graduated Boolean @default(false)
  socials socials?
  tokenHash tokenHash? 
  lastTimeStamp String @default("0")
}


model tokenHash{
  hash String  @id
  coinId String @unique 
  coin coin @relation(fields: [coinId], references: [id])
}
   


model apiKeys{
  id String @id @default(cuid())
  apiKey String @unique
  userId String 
  user user @relation(fields: [userId], references: [publicKey])
}

model blockTimeStamps {
  id String @id @default("singleton")

  tokenDeployedsTimestamp  String @default("0")
  tokenDeployedsLastId     String @default("0")

  tokenGraduatedsTimestamp String @default("0")
  tokenGraduatedsLastId    String @default("0")

  tokenBoughtsTimestamp    String @default("0")
  tokenBoughtsLastId       String @default("0")

  tokenSoldsTimestamp      String @default("0")
  tokenSoldsLastId         String @default("0")

  poolcreatedsTimestamp    String @default("0")
  poolcreatedsLastId       String @default("0")

  tokencreatedsTimestamp   String @default("0")
  tokencreatedLastId       String @default("0")

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}


model message{
  id String @id @default(cuid())
  message String? 
  userKey String
  coinId String
  coin coin @relation(fields: [coinId], references: [address])
  user user @relation(fields: [userKey], references: [publicKey])
  referencedImage messageImage?
  referencedMessageId String?
  referencedMessage message? @relation("MessageReplies", fields: [referencedMessageId], references: [id])
  referees message[] @relation("MessageReplies")
  dateTime DateTime @default(now()) 
}

model messageImage{
  id String @id @default(cuid())
  address String 
  messageId String @unique
  message message @relation(fields: [messageId], references: [id])
}



